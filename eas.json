{
  "cli": {
    "version": ">= 16.0.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_ENV": "development",
        "EXPO_PUBLIC_WS_URL": "wss://dev.api.comptt.melbourne.vic.gov.au/ws",
        "EXPO_PUBLIC_REST_URL": "https://dev.api.comptt.melbourne.vic.gov.au"
      }
    },
    "preview": {
      "distribution": "internal",
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_ENV": "preview",
        "EXPO_PUBLIC_WS_URL": "wss://preview.api.comptt.melbourne.vic.gov.au/ws",
        "EXPO_PUBLIC_REST_URL": "https://preview.api.comptt.melbourne.vic.gov.au"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_ENV": "production",
        "EXPO_PUBLIC_WS_URL": "wss://api.comptt.melbourne.vic.gov.au/ws",
        "EXPO_PUBLIC_REST_URL": "https://api.comptt.melbourne.vic.gov.au"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
