{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "noUncheckedIndexedAccess": true,
    "baseUrl": ".",
    "paths": {
      "@/*":            ["src/*"],
      "@app/*":         ["src/app/*"],
      "@components/*":  ["src/components/*"],
      "@hooks/*":       ["src/hooks/*"],
      "@services/*":    ["src/services/*"],
      "@providers/*":   ["src/providers/*"],
      "@types/*":       ["src/types/*"],
      "@constants/*":   ["src/constants/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.d.ts",
    "expo-env.d.ts"
  ]
}
